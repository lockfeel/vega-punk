{
  "permissions": {
    "allow": [
      "Bash:*",
      "Bash:git:*",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Agent",
      "TaskList",
      "TaskGet",
      "TaskCreate",
      "TaskUpdate"
    ],
    "deny": [
      "Bash:sudo:*",
      "Bash:rm:--rf:/",
      "Bash:rm:--rf:/*"
    ]
  }
}
