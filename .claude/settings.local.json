{
  "permissions": {
    "allow": [
      "Bash:*",
      "Bash:git:*",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Agent",
      "TaskList",
      "TaskGet",
      "TaskCreate",
      "TaskUpdate"
    ],
    "deny": [
      "Bash:sudo:*",
      "Bash:rm:--rf:/",
      "Bash:rm:--rf:/*",
      "Bash:curl:--pipe:sh",
      "Bash:wget:--pipe:sh",
      "Bash:mkfs:*",
      "Bash:dd:*",
      "Bash:chmod:777",
      "Bash:chmod:000",
      "/"
    ]
  }
}
